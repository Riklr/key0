{
	"permissions": {
		"deny": [
			"Bash(git push --force*)",
			"Bash(git push -f*)"
		]
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-push-readme.sh\""
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "cd \"$CLAUDE_PROJECT_DIR\" && bunx biome check --write --unsafe \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
					}
				]
			}
		]
	}
}
